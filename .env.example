# Server
PORT=3000
ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/fluxa?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# Stellar
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
# USDC issuer on Stellar testnet
STELLAR_USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5

# Key management — must be exactly 64 hex characters (32 bytes)
# Generate with: openssl rand -hex 32
MASTER_ENCRYPTION_KEY=replace_with_64_char_hex_string

# Treasury wallet funds newly created accounts (testnet: leave empty, use Friendbot)
TREASURY_SECRET_KEY=

# Platform fee collection wallet (Stellar public key)
PLATFORM_FEE_WALLET_PUBLIC_KEY=

# Migrations path (relative to binary working directory)
MIGRATIONS_PATH=db/migrations

# Alerting webhook URL (Slack or generic webhook for reconciliation alerts)
# Leave empty to disable alerting
ALERT_WEBHOOK_URL=
